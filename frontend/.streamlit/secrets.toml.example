# Copy this file to .streamlit/secrets.toml and fill in your values
# NEVER commit secrets.toml to GitHub

WATSONX_API_KEY    = "your_ibm_cloud_api_key_here"
WATSONX_PROJECT_ID = "your_watsonx_project_id_here"

# Regional URL — pick your region:
# us-south (Dallas):  https://us-south.ml.cloud.ibm.com
# eu-de (Frankfurt):  https://eu-de.ml.cloud.ibm.com
# ap-north (Tokyo):   https://jp-tok.ml.cloud.ibm.com
WATSONX_URL = "https://us-south.ml.cloud.ibm.com"

# Model ID — pick what's available in your region:
# us-south: ibm/granite-3-2-8b-instruct
# eu-de:    meta-llama/llama-3-1-8b-instruct
# ap-north: mistralai/mistral-large
GRANITE_MODEL_ID = "ibm/granite-3-2-8b-instruct"
